firmware/MDK-ARM/**/*.crf export-ignore
firmware/MDK-ARM/**/*.d export-ignore
firmware/MDK-ARM/**/*.dep export-ignore
firmware/MDK-ARM/**/*.axf export-ignore
firmware/MDK-ARM/**/*.hex export-ignore
firmware/MDK-ARM/**/*.htm export-ignore
firmware/MDK-ARM/**/*.lst export-ignore
firmware/MDK-ARM/**/*.log export-ignore
firmware/MDK-ARM/**/*.map export-ignore
